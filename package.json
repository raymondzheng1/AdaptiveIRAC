{
  "name": "adaptive-irac",
  "version": "0.1.0",
  "private": true,
  "description": "Free, login-free exam practice that grounds every IRAC answer in the student's own uploaded course materials, citing only verified, pinpointed authorities.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "no-ai:check": "node scripts/no-ai-mentions-check.mjs",
    "citation:check": "node scripts/citation-format-check.mjs",
    "tokens:check": "node scripts/tokens-check.mjs",
    "verify": "node scripts/no-ai-mentions-check.mjs && node scripts/citation-format-check.mjs && node scripts/tokens-check.mjs && npm run lint && vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@upstash/redis": "^1.34.3",
    "jszip": "^3.10.1",
    "mammoth": "^1.8.0",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "unpdf": "^0.12.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.1.6",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
