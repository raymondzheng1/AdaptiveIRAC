# Adaptive IRAC — environment variables (placeholders only; real secrets never committed)

# --- Anthropic (server-side model calls) ---
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# --- Upstash Redis (cost meter + rate limit; fail-closed when unset in prod) ---
UPSTASH_REDIS_REST_URL=https://REPLACE_ME.upstash.io
UPSTASH_REDIS_REST_TOKEN=REPLACE_ME

# --- Cost guard ---
# Hard per-session model-spend cap, in US dollars.
SESSION_CAP_USD=5
# Global daily operator budget, in US dollars. When exhausted, shared tier pauses (BYO-key still works).
GLOBAL_DAILY_BUDGET_USD=50

# --- App ---
APP_BASE_URL=http://localhost:3000

# --- Analytics (optional; PII-safe GA4) ---
NEXT_PUBLIC_GA4_ID=

# --- Operator budget alerts (optional) ---
RESEND_API_KEY=
OPERATOR_ALERT_EMAIL=
CRON_SECRET=

# --- Dev conveniences (non-prod only) ---
# When set in dev/test, allows the app to run without Upstash using an in-memory KV.
# In production the cost guard fails CLOSED if Upstash is unconfigured.
ALLOW_INSECURE_DEV_KV=true
